# ──────────────────────────────────────────────
# Evento.so API
# Used to synchronize and retrieve event information.
# ──────────────────────────────────────────────

# API key provided by Evento.so
EVENTO_SO_API_KEY=your-evento-api-key

# Evento.so account username or organization slug
EVENTO_SO_USERNAME=your-evento-username

# ──────────────────────────────────────────────
# Ghost CMS
# Shared Ghost instance used by Vinteum.
# These credentials are used exclusively on the server.
# Never expose the Admin API Key to the client.
# ──────────────────────────────────────────────

# Ghost site URL
GHOST_URL=https://blog.example.org

# Ghost Admin API Key
# Ghost Admin → Settings → Integrations → Your Custom Integration
GHOST_ADMIN_API_KEY=your-ghost-admin-api-key